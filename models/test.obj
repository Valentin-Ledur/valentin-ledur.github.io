# Un simple cube texturé et triangulé pour WebGPU
# Sommets (Positions 3D)
v 1.0 -1.0 -1.0
v 1.0 -1.0 1.0
v -1.0 -1.0 1.0
v -1.0 -1.0 -1.0
v 1.0 1.0 -1.0
v 1.0 1.0 1.0
v -1.0 1.0 1.0
v -1.0 1.0 -1.0

# Coordonnées UV (Pour la texture)
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
vt 0.0 0.0

# Normales (Pour calculer la lumière)
vn 0.0 -1.0 0.0
vn 0.0 1.0 0.0
vn 1.0 0.0 0.0
vn -0.0 -0.0 1.0
vn -1.0 -0.0 -0.0
vn 0.0 0.0 -1.0

# Faces (Triangles au format sommet/uv/normale)
f 2/1/1 3/2/1 4/3/1
f 8/2/2 7/3/2 6/4/2
f 5/4/3 6/1/3 2/2/3
f 6/4/4 7/1/4 3/2/4
f 3/2/5 7/3/5 8/4/5
f 1/4/6 4/1/6 8/2/6
f 1/4/1 2/1/1 4/3/1
f 5/1/2 8/2/2 6/4/2
f 1/3/3 5/4/3 2/2/3
f 2/3/4 6/4/4 3/2/4
f 4/1/5 3/2/5 8/4/5
f 5/3/6 1/4/6 8/2/6